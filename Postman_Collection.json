{
  "info": {
    "_postman_id": "distribuidos-api-test",
    "name": "Distribuidos - API Testing",
    "description": "Colección para probar ms-suppliers con actualización de proveedores",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "1. Register User",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\"username\":\"testadmin\",\"password\":\"Admin123!@\"}"
        },
        "url": {
          "raw": "http://localhost:8080/ms-auth/auth/register",
          "protocol": "http",
          "host": ["localhost"],
          "port": "8080",
          "path": ["ms-auth", "auth", "register"]
        }
      }
    },
    {
      "name": "2. Login",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\"username\":\"testadmin\",\"password\":\"Admin123!@\"}"
        },
        "url": {
          "raw": "http://localhost:8080/ms-auth/auth/login",
          "protocol": "http",
          "host": ["localhost"],
          "port": "8080",
          "path": ["ms-auth", "auth", "login"]
        }
      }
    },
    {
      "name": "3. Create Supplier",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          },
          {
            "key": "Authorization",
            "value": "Bearer {{token}}",
            "description": "Copiar token del paso 2 (Login)"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\"nit\":\"1234567890\",\"nombre\":\"Proveedor XYZ S.A.S\",\"email\":\"contacto@xyz.com\",\"telefono\":\"3001234567\",\"estado\":true}"
        },
        "url": {
          "raw": "http://localhost:8080/ms-suppliers/suppliers",
          "protocol": "http",
          "host": ["localhost"],
          "port": "8080",
          "path": ["ms-suppliers", "suppliers"]
        }
      }
    },
    {
      "name": "4. Get Supplier (GET)",
      "request": {
        "method": "GET",
        "header": [
          {
            "key": "Authorization",
            "value": "Bearer {{token}}"
          }
        ],
        "url": {
          "raw": "http://localhost:8080/ms-suppliers/suppliers/{{supplierId}}",
          "protocol": "http",
          "host": ["localhost"],
          "port": "8080",
          "path": ["ms-suppliers", "suppliers", "{{supplierId}}"]
        }
      }
    },
    {
      "name": "5. Update Supplier (PUT) - MAIN TEST",
      "request": {
        "method": "PUT",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          },
          {
            "key": "Authorization",
            "value": "Bearer {{token}}"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\"nit\":\"1234567890\",\"nombre\":\"Proveedor XYZ Actualizado\",\"email\":\"nuevo@xyz.com\",\"telefono\":\"3009876543\",\"estado\":true}"
        },
        "url": {
          "raw": "http://localhost:8080/ms-suppliers/suppliers/{{supplierId}}",
          "protocol": "http",
          "host": ["localhost"],
          "port": "8080",
          "path": ["ms-suppliers", "suppliers", "{{supplierId}}"]
        }
      }
    },
    {
      "name": "6. Test NIT Change Prevention",
      "request": {
        "method": "PUT",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          },
          {
            "key": "Authorization",
            "value": "Bearer {{token}}"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\"nit\":\"9999999999\",\"nombre\":\"Intento Cambiar NIT\",\"email\":\"test@xyz.com\",\"telefono\":\"3001111111\",\"estado\":true}"
        },
        "url": {
          "raw": "http://localhost:8080/ms-suppliers/suppliers/{{supplierId}}",
          "protocol": "http",
          "host": ["localhost"],
          "port": "8080",
          "path": ["ms-suppliers", "suppliers", "{{supplierId}}"]
        }
      }
    },
    {
      "name": "7. Direct Access Test (Should be blocked - USE THIS TO VERIFY)",
      "request": {
        "method": "GET",
        "header": [
          {
            "key": "Authorization",
            "value": "Bearer {{token}}"
          }
        ],
        "url": {
          "raw": "http://localhost:8083/suppliers/{{supplierId}}",
          "protocol": "http",
          "host": ["localhost"],
          "port": "8083",
          "path": ["suppliers", "{{supplierId}}"]
        }
      }
    }
  ],
  "variable": [
    {
      "key": "token",
      "value": "PASTE_LOGIN_TOKEN_HERE",
      "type": "string"
    },
    {
      "key": "supplierId",
      "value": "PASTE_SUPPLIER_ID_HERE",
      "type": "string"
    }
  ]
}
